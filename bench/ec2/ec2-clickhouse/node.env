# Config for the ClickHouse host. 22 from operator; 8123 (HTTP) + 9000 (native)
# from operator and the whole VPC so the walshadow/peerdb boxes can emit into it.
NODE_NAME=walshadow-clickhouse
SG_DESC="walshadow clickhouse: SSH from my IP; HTTP/native from my IP + VPC"
INGRESS="22:my 8123:my,vpc 9000:my,vpc"
NODE_NEXT="check:     curl http://<public-ip>:8123/ping  (once cloud-init finishes)"
