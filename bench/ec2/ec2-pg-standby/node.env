# Config for the PG-standby host. SSH from operator; PG (:5432) from operator +
# VPC (the bench connects to it as the replication destination).
NODE_NAME=walshadow-pg-standby
SG_DESC="walshadow pg standby: SSH from my IP; PG from my IP + VPC"
INGRESS="22:my 5432:my,vpc"
NODE_NEXT="next:      ./deploy.sh pg_basebackup from primary + starts streaming standby"
