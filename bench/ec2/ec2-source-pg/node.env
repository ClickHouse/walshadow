# Config for the source Postgres host. SSH + PG (:5432) from operator + VPC.
# STATE_PRIVATE_ALIASES adds SOURCE_PRIVATE_IP=<private ip> to state.env, which
# deploy.sh (walshadow/peerdb/pg-standby) and the bench (--network private) read.
NODE_NAME=walshadow-source-pg
SG_DESC="walshadow source postgres: SSH+PG from my IP and VPC"
INGRESS="22:my,vpc 5432:my,vpc"
STATE_PRIVATE_ALIASES="SOURCE_PRIVATE_IP"
NODE_NEXT="psql:      psql -h <public-ip> -U postgres -d postgres"
