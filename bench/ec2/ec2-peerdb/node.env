# Config for the self-hosted PeerDB host. SSH + PeerDB UI (:3000) / SQL (:9900)
# from the operator; MinIO (:9001) from the VPC. Needs a bit more disk (compose
# stack + MinIO staging), hence VOLUME_SIZE=40.
NODE_NAME=walshadow-peerdb
SG_DESC="walshadow peerdb: SSH + PeerDB UI/SQL from my IP; MinIO from VPC"
INGRESS="22:my 3000:my 9900:my 9001:vpc"
VOLUME_SIZE=40
NODE_NEXT="next:      ./deploy.sh brings up the PeerDB stack + creates the mirror"
