# Config for the in-VPC benchmark-runner host. Only SSH inbound; it reaches the
# source/ClickHouse/standby OUTBOUND over the VPC (their SGs allow the VPC CIDR).
NODE_NAME=walshadow-bench
SG_DESC="walshadow bench runner: SSH from my IP"
INGRESS="22:my"
NODE_NEXT="next:      ./deploy.sh ships the bench image + endpoints + wrapper"
