// walshadow — cursor durability + slot-advance feedback loop
// status_loop is the orchestrator: gathers LSN inputs from xact buffer,
// segment sink, shadow-replay sweeper, walsender-rx standby frames →
// writes cursor.bin (atomic rename, CRC32C) → emits standby-status
// triple to source slot → feeds retention sweeper & Prom metrics.
//
// regeneration spec:
// sources of truth: plans/ops.md · src/cursor.rs · src/preflight.rs · src/retention.rs · src/metrics.rs
// subsumes: plans/ops.md § "Cursor file" + "Slot advance" + apply-lag metric
// quality bar:
//   - cursor write edge (magenta dotted) reads as durability path
//   - slot-advance edge clearly back to source PG, not confused with metrics export
//   - preflight noted as boot-only (not in tick loop)
// shared style: palette.md
digraph ops {
  rankdir=TB;
  compound=true;
  newrank=true;
  graph [fontname="Helvetica", labelloc="t", label="walshadow — cursor durability + slot advance (status_loop, 10 s cadence)", fontsize=14, splines=spline, nodesep=0.4, ranksep=0.8, bgcolor="#272623", fontcolor="#ECE1D7"];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", color="#6E6963", fontcolor="#ECE1D7"];
  edge  [fontname="Helvetica", fontsize=9, color="#c1a78e", fontcolor="#ECE1D7"];

  // ═════ External endpoints ═════
  shd   [label="shadow PG\npg_last_wal_replay_lsn()\n+ walreceiver 'r' frames", fillcolor="#3D4128", shape=cylinder];
  src   [label="source PG\npg_replication_slots\nconfirmed_flush_lsn", fillcolor="#3D3D54", shape=cylinder];
  prom  [label="Prometheus scrape\n/metrics", fillcolor="#3D3D54", shape=cylinder];

  // ═════ A. LSN inputs (left column, fed by xact/segment/wire) ═════
  subgraph cluster_inputs {
    label="LSN sources (single source of truth per field)";
    style="rounded,filled"; color="#4c4641"; fillcolor="#34302c"; fontcolor="#ECE1D7";

    feed     [label="SourceFeed::pump\nlast_server_wal_end\n→ source_received_lsn", fillcolor="#3D3D54"];
    segsink  [label="DirSegmentSink::on_segment\nfsync seg + dir\n→ filter_durable_lsn\n(= flush advertised)", fillcolor="#4D3340"];
    xact     [label="XactBuffer stats.drain_lsn\n+ pipeline ack collector\nemitter_ack atomic\n(contiguous-done watermark)", fillcolor="#4D4128"];
    sweeper  [label="retention_task (30 s)\nSELECT pg_last_wal_replay_lsn()\n→ Arc&lt;AtomicU64&gt; shadow_replay_lsn", fillcolor="#4D3A28"];
    walsrv   [label="walsender server\nrx 'r' standby frames\nShadowStreamState::aggregate\n→ min_flush_lsn", fillcolor="#5D3F40"];
  }

  // ═════ B. status_loop orchestrator (centre column) ═════
  subgraph cluster_status {
    label="status_loop (bin/stream.rs, --status-interval = 10 s)";
    style="rounded,filled"; color="#4c4641"; fillcolor="#34302c"; fontcolor="#ECE1D7";

    snap   [label="snapshot 6 LSNs\nbuild Cursor { … }", fillcolor="#4D3A28"];
    apply  [label="apply_ceiling =\nshadow_replay==0\n  ? emitter_ack\n  : min(shadow_replay, emitter_ack)", fillcolor="#4D3A28"];
    cwrite [label="cursor::write\ntmp → fsync → rename → fsync_dir", fillcolor="#4D3A28"];
    triple [label="StandbyStatus {\n  write = source_received,\n  flush = filter_durable,\n  apply = apply_ceiling\n}", fillcolor="#4D3A28"];
    sendst [label="SourceFeed::send_status\n'r' frame on replication socket", fillcolor="#3D3D54"];
    snap -> apply;
    snap -> cwrite [color="#b380b0", style=dotted, penwidth=2];
    apply -> triple;
    triple -> sendst;
  }

  // ═════ C. Sinks (right column) ═════
  cursor_bin [label="{spill_dir}/cursor.bin\n64 B, schema v2, CRC32C\natomic rename via cursor.bin.tmp\n(boot: emitter_ack_lsn is\nresume floor, seg-aligned)", fillcolor="#4D3850", shape=note];

  outdir [label="out/<seg>\nfiltered 16 MiB WAL\n+ manifest.json", fillcolor="#4D3850", shape=note];

  trim   [label="trim_below_lsn\ncutoff = shadow_replay\n  − retention_bytes\n(default 256 MiB)", fillcolor="#4D3A28"];

  metrics [label="MetricsSnapshot → text\nwalshadow_*_lsn gauges,\nshadow_apply_lag_bytes/seconds,\nRateEstimator (30 s window)", fillcolor="#4D4128"];

  // ═════ Wiring ═════
  // shadow PG sits left of the inputs cluster, feeds sweeper + walsrv
  shd -> sweeper [style=dashed, color="#CBA85E", label="libpq SELECT"];
  shd -> walsrv  [style=dashed, color="#BD8183", label="walreceiver 'r'"];

  // Inputs → status_loop snapshot (all converge on `snap`)
  feed    -> snap [label="source_received_lsn"];
  segsink -> snap [label="filter_durable_lsn"];
  xact    -> snap [label="drain_lsn,\nemitter_ack_lsn"];
  sweeper -> snap [label="shadow_replay_lsn"];
  walsrv  -> snap [label="shadow_flush_lsn", color="#BD8183"];

  // Cursor durability path (MAIN — purple dotted)
  cwrite -> cursor_bin [color="#b380b0", style=dotted, penwidth=2, label="every 10 s\n(atomic rename)"];

  // Slot advance path
  sendst -> src [color="#A1A9CC", penwidth=2, label="standby-status triple\n(write/flush/apply)"];

  // Retention sweeper trims outdir below shadow_replay − retention_bytes
  sweeper -> trim   [color="#6E6963", style=dashed];
  trim    -> outdir [color="#6E6963", style=dashed, label="rm < cutoff"];

  // Metrics tap (off main flow but ranks below snap so it points down with gravity)
  snap    -> metrics [style=dashed, color="#CBA85E", label="LSN gauges +\napply_lag_*"];
  metrics -> prom    [color="#A1A9CC", label="HTTP /metrics"];

  // Rank pinning so external endpoints anchor each side
  { rank=same; shd; feed; }
  { rank=same; src; cursor_bin; }

  // cursor.bin layout reference table
  cursor_table [shape=plaintext, label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5">
      <TR><TD COLSPAN="3" BGCOLOR="#4D3850"><B>cursor.bin layout — 64 B, schema v2</B></TD></TR>
      <TR BGCOLOR="#34302c">
        <TD><B>offset</B></TD><TD><B>field</B></TD><TD><B>role</B></TD>
      </TR>
      <TR><TD>0..8</TD><TD>MAGIC "WSCRSR\x01\x00"</TD><TD>file id + reserved</TD></TR>
      <TR><TD>8..12</TD><TD>version u32 LE</TD><TD>schema = 2 (added shadow_flush_lsn)</TD></TR>
      <TR><TD>12..20</TD><TD>source_received_lsn</TD><TD>bookkeeping, gates nothing</TD></TR>
      <TR><TD>20..28</TD><TD>filter_durable_lsn</TD><TD>standby flush_lsn advertised</TD></TR>
      <TR><TD>28..36</TD><TD>shadow_replay_lsn</TD><TD>apply ceiling (when nonzero)</TD></TR>
      <TR><TD>36..44</TD><TD>drain_lsn</TD><TD>observer; ≥ emitter_ack</TD></TR>
      <TR><TD>44..52</TD><TD><B>emitter_ack_lsn</B></TD><TD><B>resume LSN + apply ceiling</B></TD></TR>
      <TR><TD>52..60</TD><TD>shadow_flush_lsn</TD><TD>walsender hands shadow back here</TD></TR>
      <TR><TD>60..64</TD><TD>crc32c u32 LE</TD><TD>covers bytes 0..60 (PG-compatible CRC)</TD></TR>
    </TABLE>
  >];
  cursor_bin -> cursor_table [style=invis];

  // Legend
  legend [shape=plaintext, label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#34302c"><B>node fill — role</B></TD></TR>
      <TR><TD BGCOLOR="#3D3D54" WIDTH="28"></TD><TD>source PG / ingress</TD></TR>
      <TR><TD BGCOLOR="#4D3A28"></TD><TD>walshadow status / retention</TD></TR>
      <TR><TD BGCOLOR="#4D3340"></TD><TD>walshadow segment sink</TD></TR>
      <TR><TD BGCOLOR="#4D4128"></TD><TD>walshadow xact buffer / metrics</TD></TR>
      <TR><TD BGCOLOR="#5D3F40"></TD><TD>walshadow walsender server</TD></TR>
      <TR><TD BGCOLOR="#4D3850"></TD><TD>on-disk artifact</TD></TR>
      <TR><TD BGCOLOR="#3D4128"></TD><TD>shadow Postgres</TD></TR>
      <TR><TD COLSPAN="2" BGCOLOR="#34302c"><B>edge colour</B></TD></TR>
      <TR><TD><FONT COLOR="#A1A9CC"><B>━━</B></FONT></TD><TD>source replication ('r' standby) / Prom scrape</TD></TR>
      <TR><TD><FONT COLOR="#BD8183"><B>━━</B></FONT></TD><TD>walsender wire ('r' from shadow)</TD></TR>
      <TR><TD><FONT COLOR="#CBA85E"><B>━━</B></FONT></TD><TD>libpq catalog query / metrics tap</TD></TR>
      <TR><TD><FONT COLOR="#b380b0"><B>···</B></FONT></TD><TD>cursor durability (atomic rename, CRC32C)</TD></TR>
      <TR><TD><FONT COLOR="#6E6963"><B>┄┄</B></FONT></TD><TD>filesystem (segment trim)</TD></TR>
    </TABLE>
  >];
  cursor_table -> legend [style=invis];
}
