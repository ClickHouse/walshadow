// walshadow — clickhouse-c-rs FFI trust boundary
// Static structural view: who owns what on the Rust side, what crosses
// the boundary, what we trust on the C side. Six unsafe holes from the
// UNSAFE landing (audited 2026-05-17 at commit b5af579) marked beside
// the component they constrain; full prose lives in the legend below.
//
// regeneration spec:
// sources of truth: plans/safety.md · clickhouse-c-rs/ (Client<'fd>, PosixIo<'fd>, Codec) · audit b5af579 @ 2026-05-17
// subsumes: plans/safety.md § unsafe surface enumeration + lifetime relationships
// quality bar:
//   - six unsafe holes visible without overlapping their owners
//   - ownership tree (Client → PosixIo → BorrowedFd) reads cleanly
//   - FFI crossings clearly bidirectional (call + return)
//   - "TRUST BOUNDARY" divider unambiguous
// shared style: palette.md
digraph safety {
  rankdir=TB;
  compound=true;
  graph [fontname="Helvetica", labelloc="t", label="walshadow safety — clickhouse-c-rs Rust ↔ C FFI trust boundary (audited 2026-05-17 @ b5af579)", fontsize=14, splines=spline, nodesep=0.4, ranksep=0.8, bgcolor="#272623", fontcolor="#ECE1D7"];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", color="#6E6963", fontcolor="#ECE1D7"];
  edge  [fontname="Helvetica", fontsize=9, color="#c1a78e", fontcolor="#ECE1D7"];
  // bigger xlabels for the ①…⑥ hole markers next to owners
  forcelabels=true;

  // ════════ Caller (walshadow CH emitter) ════════
  caller [label="walshadow CH emitter\nplans/emitter.md\nowns Client<'static> for daemon life", fillcolor="#5D4628"];

  // ════════ Rust side — owning types & lifetime tree ════════
  subgraph cluster_rust {
    label="Rust side — clickhouse-c-rs (owning types, lifetime: 'fd)"; style="rounded,filled"; color="#4c4641"; fillcolor="#34302c"; fontcolor="#ECE1D7";

    client    [label="Client<'fd>\nclient.rs:142\nNonNull<chc_client>", fillcolor="#5D4628", xlabel=<<FONT COLOR="#B58B86" POINT-SIZE="16"><B>①</B></FONT>>];
    alloc     [label="alloc:\nBox<Allocator>\nstdlib", fillcolor="#5D4628"];
    codec     [label="_codec:\nPin<Box<Codec>>\nlz4 / zstd\n!Unpin", fillcolor="#5D4628", xlabel=<<FONT COLOR="#B58B86" POINT-SIZE="16"><B>③</B></FONT>>];
    posix     [label="_io:\nPin<Box<PosixIo<'fd>>>\nio.rs:17\nstate + io + owned\n!Unpin", fillcolor="#5D4628", xlabel=<<FONT COLOR="#B58B86" POINT-SIZE="16"><B>⑥</B></FONT>>];
    builder   [label="BlockBuilder<'a>\nblock.rs\nno-copy slabs", fillcolor="#5D4628", xlabel=<<FONT COLOR="#B58B86" POINT-SIZE="16"><B>② ⑤</B></FONT>>];
    fd        [label="BorrowedFd<'fd>\nTCP / OwnedFd → 'static", fillcolor="#3D3D54", shape=cylinder];

    client -> alloc;
    client -> codec;
    client -> posix;
    posix  -> fd     [label="borrows", style=dashed];
  }
  caller -> client [label="Client::init", lhead=cluster_rust];
  caller -> builder [label="fill per batch", style=dashed, constraint=false];

  // ════════ C side — FFI surface & trusted base ════════
  subgraph cluster_c {
    label="C side — sys:: FFI + clickhouse-c (trusted base)"; style="rounded,filled"; color="#4c4641"; fillcolor="#34302c"; fontcolor="#ECE1D7";

    ffi   [label="sys:: extern \"C\"\nchc_client_init / send_query / send_data /\nrecv_packet / chc_posix_io_init / chc_codec_*", fillcolor="#4D4128"];
    cstruct [label="chc_client { al, io, codec }\nback-ptrs into our Pin<Box<_>> fields", fillcolor="#4D4128"];
    cclient [label="clickhouse-c\n(out of scope — trusted)\nn_rows / offsets.last() / name_len\nconsistent with buffers", fillcolor="#4D4128", shape=cylinder, xlabel=<<FONT COLOR="#B58B86" POINT-SIZE="16"><B>④</B></FONT>>];

    ffi -> cstruct [style=dashed, label="init wires"];
    cstruct -> cclient [style=dashed];
  }

  // ════════ Trust-boundary crossings ════════
  client  -> ffi [label="send_query /\nsend_data /\nrecv_packet", color="#BF8C5F", penwidth=2];
  builder -> ffi [label="bb_ptr\nvalid 'a", color="#BF8C5F", penwidth=1.5];
  posix   -> ffi [label="io_ptr()\npub(crate)", color="#BF8C5F", penwidth=1.5, style=dashed];

  // ════════ Legend ════════
  node  [shape=plaintext, fillcolor="#272623", color="#272623", style="", fontsize=10];
  legend [label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
      <TR><TD COLSPAN="2" BGCOLOR="#34302c"><B>unsafe holes — UNSAFE landing (b5af579)</B></TD></TR>
      <TR><TD><FONT COLOR="#B58B86"><B>①</B></FONT></TD><TD><B>Client ownership of PosixIo / Codec</B> — <FONT FACE="monospace">Pin&lt;Box&gt;</FONT> for drop order + address stability; C back-ptrs live through <FONT FACE="monospace">Drop</FONT></TD></TR>
      <TR><TD><FONT COLOR="#B58B86"><B>②</B></FONT></TD><TD><B>&amp;[u8] over &amp;str</B> — no <FONT FACE="monospace">from_utf8_unchecked</FONT>; text accessors return bytes, <FONT FACE="monospace">format()</FONT> uses <FONT FACE="monospace">from_utf8_lossy</FONT></TD></TR>
      <TR><TD><FONT COLOR="#B58B86"><B>③</B></FONT></TD><TD><B>Codec::raw_mut unsafe</B> — caller installs fn-ptr table matching <FONT FACE="monospace">chc_codec</FONT> signatures; <FONT FACE="monospace">ud</FONT> alive for codec lifetime</TD></TR>
      <TR><TD><FONT COLOR="#B58B86"><B>④</B></FONT></TD><TD><B>C-side trust boundary</B> — release trusts <FONT FACE="monospace">clickhouse-c</FONT> invariants (<FONT FACE="monospace">n_rows</FONT>, <FONT FACE="monospace">offsets.last()</FONT>); no API to query alloc cap</TD></TR>
      <TR><TD><FONT COLOR="#B58B86"><B>⑤</B></FONT></TD><TD><B>checked_mul at FFI size params</B> — <FONT FACE="monospace">Column::fixed</FONT> / <FONT FACE="monospace">low_cardinality</FONT> use <FONT FACE="monospace">n_rows.checked_mul(elem_size)</FONT> → <FONT FACE="monospace">Option</FONT></TD></TR>
      <TR><TD><FONT COLOR="#B58B86"><B>⑥</B></FONT></TD><TD><B>BorrowedFd discipline</B> — <FONT FACE="monospace">'fd</FONT> ties <FONT FACE="monospace">Client</FONT> to fd lifetime (was raw <FONT FACE="monospace">c_int</FONT> pre-UNSAFE 6); <FONT FACE="monospace">new_owned</FONT> → <FONT FACE="monospace">'static</FONT></TD></TR>
      <TR><TD COLSPAN="2" BGCOLOR="#34302c"><B>edge — kind</B></TD></TR>
      <TR><TD><FONT COLOR="#c1a78e"><B>━━</B></FONT></TD><TD>ownership / composition</TD></TR>
      <TR><TD><FONT COLOR="#BF8C5F"><B>━━</B></FONT></TD><TD>FFI call crossing the trust boundary</TD></TR>
      <TR><TD COLSPAN="2" BGCOLOR="#34302c"><B>node fill — role</B></TD></TR>
      <TR><TD BGCOLOR="#5D4628" WIDTH="28"></TD><TD>walshadow CH emitter / Rust types</TD></TR>
      <TR><TD BGCOLOR="#4D4128"></TD><TD>C-side FFI + clickhouse-c</TD></TR>
      <TR><TD BGCOLOR="#3D3D54"></TD><TD>kernel-level resource (fd)</TD></TR>
    </TABLE>
  >];
  cclient -> legend [style=invis];
}
